# ── Hyperledger Fabric crypto material ───────────────────────────────────────
# Generated by fabric-ca / cryptogen — never commit private keys
Blockchain/artifacts/channel/crypto-config/
Blockchain/artifacts/channel/create-certificate-with-ca/fabric-ca/*/msp/keystore/
Blockchain/artifacts/channel/create-certificate-with-ca/fabric-ca/*/*.db
Blockchain/artifacts/channel/create-certificate-with-ca/fabric-ca/*/IssuerSecretKey
Blockchain/artifacts/channel/create-certificate-with-ca/fabric-ca/*/IssuerRevocationPrivateKey

# Generated channel artifacts (reproducible via create-artifacts.sh)
Blockchain/channel-artifacts/
Blockchain/artifacts/channel/*.block
Blockchain/artifacts/channel/*.tx

# Fabric CA server state (runtime files)
Blockchain/artifacts/channel/create-certificate-with-ca/fabric-ca/*/*.db
Blockchain/artifacts/channel/create-certificate-with-ca/fabric-ca/*/tls-cert.pem

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
# Keep CA public certs (not private keys) — they are needed by SDK clients
!**/tlscacerts/**
!**/cacerts/**
!**/signcerts/**
!**/*-cert.pem
!**/ca.crt
!**/tls.crt

# ── Docker ────────────────────────────────────────────────────────────────────
# Local override files (machine-specific port/volume overrides)
docker-compose.override.yml

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Build / test output ───────────────────────────────────────────────────────
coverage/
dist/
build/

# ── Claude Code internal ──────────────────────────────────────────────────────
.claude/
